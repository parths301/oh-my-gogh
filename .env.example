# Oh my Gogh! — environment variables
# Set these in Vercel → Project → Settings → Environment Variables.
# Never commit real values. The SERVICE_ROLE and RAZORPAY_KEY_SECRET are
# server-only and must NEVER be exposed to the browser.

# --- Supabase (Project → Settings → API) ---
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...            # public (RLS-protected); sent to the browser via /api/config
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...     # SECRET — server only (order writes)

# --- Razorpay (Dashboard → Settings → API Keys; use TEST keys first) ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx         # public key id (sent to the browser)
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx      # SECRET — server only

# --- Store ---
STORE_CURRENCY=INR
FREE_SHIPPING_OVER=2000                   # free shipping at/above this (whole rupees)
FLAT_SHIPPING=99                          # otherwise this flat fee
